{
  "name": "almanac-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Floating desktop AI assistant for meetings and chat.",
  "main": "dist-electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k \"pnpm dev:react\" \"pnpm dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && pnpm build:electron && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "pnpm build:react && pnpm build:electron",
    "build:react": "vite build",
    "build:electron": "tsup --config tsup.electron.config.ts",
    "build:prod": "cross-env NODE_ENV=production pnpm build",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win nsis",
    "dist:linux": "pnpm build && electron-builder --linux AppImage deb",
    "preview": "vite preview",
    "typecheck": "tsc --build --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-separator": "^1.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "electron-log": "^5.4.1",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.12.1",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.3.2",
    "electron-builder": "^24.13.3",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "postcss-load-config": "^6.0.1",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.2.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "build": {
    "appId": "ai.memfold.almanac",
    "productName": "Almanac",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://downloads.example.com/almanac/"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Almanac-${version}-setup.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "Almanac-${version}.${ext}",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
